{
  "manifest_version": 3,
  "name": "Smart Tab Manager",
  "version": "1.1.0",
  "description": "AI-powered tab manager that groups and cleans up your browser tabs",
  "permissions": [
    "tabs",
    "storage",
    "tabGroups"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Tab Manager"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
